# Copy this file to .env.local (gitignored) and customize for your own install.

# If you're exposing the dev server under a custom hostname (e.g. via a Cloudflare Tunnel,
# reverse proxy, or port forward), set it here so Vite's host-check allows it. Comma-separate
# multiple hostnames. Leave unset for local-only use (localhost/127.0.0.1 always work).
NETMAP_ALLOWED_HOST=netmap.example.org
